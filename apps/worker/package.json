{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@community-os/config": "*",
    "@community-os/errors": "*",
    "@community-os/logger": "*",
    "@community-os/repositories": "*",
    "@community-os/types": "*",
    "@community-os/utils": "*",
    "@community-os/validation": "*",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cloudinary": "^2.0.0",
    "ioredis": "^5.0.0",
    "mongoose": "^8.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
