{
  "name": "@community-os/config",
  "version": "0.1.0",
  "private": true,
  "description": "CommunityOS config package",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "zod": "^3.22.0",
    "dotenv": "^16.0.0"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "tsc --build --clean && rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "generate-docs": "ts-node src/scripts/generate-reference.ts"
  }
}